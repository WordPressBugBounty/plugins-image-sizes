msgid "Upload Image"
msgstr "ছবি আপলোড করুন"

msgid "Upload new versions of images and replace the old ones without any issues."
msgstr "ছবির নতুন সংস্করণ আপলোড করুন এবং পুরানোগুলি কোনো সমস্যা ছাড়াই প্রতিস্থাপন করুন।"

msgid "Using Classic"
msgstr "ক্লাসিক ব্যবহার করছে"

msgid "Using New Version"
msgstr "নতুন সংস্করণ ব্যবহার করছে"

msgid "View Details"
msgstr "বিস্তারিত দেখুন"

msgid "WebP Conversion Complete"
msgstr "WebP রূপান্তর সম্পূর্ণ"

msgid "WebP Conversion in Progress"
msgstr "WebP রূপান্তর চলছে"

msgid "WebP images are smaller with the same quality."
msgstr "একই গুণমানের সাথে WebP ইমেজগুলি ছোট।"

msgid "Width"
msgstr "প্রস্থ"

msgid "Worth of space saved"
msgstr "সঞ্চিত স্থানের মূল্য"

msgid "Would you like to try the new modern dashboard, or keep using the classic version?"
msgstr "আপনি নতুন আধুনিক ড্যাশবোর্ড চেষ্টা করতে চান, না ক্লাসিক সংস্করণ ব্যবহার করতে চান?"

msgid "Yes"
msgstr "হ্যাঁ"

msgid "You are using the new dashboard. Switch back to classic anytime."
msgstr "আপনি নতুন ড্যাশবোর্ড ব্যবহার করছেন। যেকোনো সময় ক্লাসিকে ফিরে যান।"

msgid "You have <strong>%d</strong> uncompressed images that are possibly slowing down your site - Boost your site speed by compressing them"
msgstr "আপনার কাছে <strong>%d</strong> সংকুচিত না করা ছবি রয়েছে যা সম্ভবত আপনার সাইটকে ধীর করছে - সেগুলি সংকুচিত করে আপনার সাইটের গতি বৃদ্ধি করুন"

msgid "You have no images to convert, please upload new images."
msgstr "রূপান্তর করার জন্য আপনার কোনো ছবি নেই, দয়া করে নতুন ছবি আপলোড করুন।"

msgid "You have no images. Please upload images."
msgstr "আপনার কোনো ছবি নেই। দয়া করে ছবি আপলোড করুন।"

msgid "Your Media Library is Silently Slowing Down Your Site."
msgstr "আপনার মিডিয়া লাইব্রেরি নীরবে আপনার সাইটকে ধীর করছে।"

msgid "Your WooCommerce store has total <strong>%d</strong> images - Find and delete unused images to save server space and money."
msgstr "আপনার WooCommerce স্টোরের মোট <strong>%d</strong> ছবি রয়েছে - সার্ভার স্থান এবং অর্থ সঞ্চয় করতে অব্যবহৃত ছবি খুঁজুন এবং মুছুন।"

msgid "Your WooCommerce store has total <strong>%d</strong> images - Save server space, speed up your site and boost sales by deleting large images."
msgstr "আপনার WooCommerce স্টোরের মোট <strong>%d</strong> ছবি রয়েছে - বড় ছবি মুছে সার্ভার স্থান সঞ্চয় করুন, আপনার সাইট গতি বৃদ্ধি করুন এবং বিক্রয় বৃদ্ধি করুন।"

msgid "Your background action failed. Please try again."
msgstr "আপনার পটভূমি ক্রিয়া ব্যর্থ হয়েছে। আবার চেষ্টা করুন।"

msgid "Your images are being converted in the background."
msgstr "আপনার ছবিগুলি পটভূমিতে রূপান্তরিত হচ্ছে।"

msgid "Your images are being converted. Please wait..."
msgstr "আপনার ছবিগুলি রূপান্তরিত হচ্ছে। অনুগ্রহ করে অপেক্ষা করুন..."

msgid "Your images are being regenerated in the background."
msgstr "আপনার ছবিগুলি পটভূমিতে পুনরায় তৈরি হচ্ছে।"

msgid "Your images are being regenerating. Please wait..."
msgstr "আপনার ছবিগুলি পুনর্নির্মাণ হচ্ছে। অনুগ্রহ করে অপেক্ষা করুন..."

msgid "Your images are ready to be optimized. Visit the dashboard to get started."
msgstr "আপনার ছবিগুলি অপ্টিমাইজ করার জন্য প্রস্তুত। শুরু করতে ড্যাশবোর্ড ভিজিট করুন।"

msgid "Your site has total <strong>%d</strong> images - Find and delete unused images to save more server space and money."
msgstr "আপনার সাইটের মোট <strong>%d</strong> ছবি রয়েছে - আরও সার্ভার স্থান এবং অর্থ সঞ্চয় করতে অব্যবহৃত ছবি খুঁজুন এবং মুছুন।"

msgid "Your site has total <strong>%d</strong> images - Save server space and speed up your site by deleting large images."
msgstr "আপনার সাইটের মোট <strong>%d</strong> ছবি রয়েছে - বড় ছবি মুছে সার্ভার স্থান সঞ্চয় করুন এবং আপনার সাইট গতি বৃদ্ধি করুন।"

msgid "[ ThumbPress Alert ] Image exceeds the maximum allowed resolution of %1$sx%2$s pixels."
msgstr "[ ThumbPress Alert ] ছবি %1$sx%2$s পিক্সেলের সর্বাধিক অনুমোদিত রেজোলিউশন অতিক্রম করে।"

msgid "[ ThumbPress Alert ] Image exceeds the maximum allowed size of %1$s %2$s."
msgstr "[ ThumbPress Alert ] ছবি %1$s %2$s এর সর্বাধিক অনুমোদিত আকার অতিক্রম করে।"

msgid "[ ThumbPress Alert ] Image exceeds the maximum allowed size of %s KB."
msgstr "[ ThumbPress Alert ] ছবি %s KB এর সর্বাধিক অনুমোদিত আকার অতিক্রম করে।"

msgid "icon"
msgstr "আইকন"

msgid "settings here"
msgstr "এখানে সেটিংস"

msgid "will be generated"
msgstr "তৈরি করা হবে"
