{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mysql": {
      "type": "local",
      "command": ["npx", "-y", "@benborla29/mcp-server-mysql"],
      "environment": {
        "MYSQL_HOST": "127.0.0.1",
        "MYSQL_PORT": "10044",
        "MYSQL_USER": "root",
        "MYSQL_PASS": "root",
        "MYSQL_DB": "local",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      },
      "enabled": true
    },
    "rest-api": {
      "type": "local",
      "command": ["npx", "-y", "dkmaker-mcp-rest-api"],
      "environment": {
        "REST_BASE_URL": "https://thumbpress.com/wp-json/thumbpress/v1",
        "AUTH_BASIC_USERNAME": "q",
        "AUTH_BASIC_PASSWORD": "q",
        "REST_ENABLE_SSL_VERIFY": "false",
        "HEADER_X-WP-Nonce": "13d9548f00"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "environment": {
        "PLAYWRIGHT_BROWSERS_PATH": "0",
        "WP_URL": "http://thumbpress.com",
        "WP_USERNAME": "q",
        "WP_PASSWORD": "q"
      },
      "enabled": true
    }
  },
  "instructions": [".opencode/skills/wordpress/SKILL.md"]
}